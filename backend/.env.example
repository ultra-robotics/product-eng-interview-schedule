# This file is OPTIONAL. The backend stores everything in a local SQLite file
# (backend/schedule.db, created automatically on first run) — no setup needed.
# Copy to .env only if you want to override a default below.

# Optional: point at a different SQLite file. May be a bare path (./schedule.db)
# or a sqlite:/// URL. Defaults to backend/schedule.db when unset.
# SCHEDULE_DATABASE_URL=./schedule.db

# Optional: enables the "edit mode" unlock in the UI.
# EDIT_PASSWORD=your-password-here
